                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": \"S001\",\n  \"status\": \"absent\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/attendance/mark",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["attendance", "mark"]
            }
