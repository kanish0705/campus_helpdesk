# Postman API Collection
# Import this JSON into Postman to test all endpoints

{
  "info": {
    "name": "Student-Parent Notification System",
    "description": "Admin Panel Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API Information",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": [""]
        }
      },
      "description": "Get API documentation and available endpoints"
    },
    {
      "name": "Setup",
      "item": [
        {
          "name": "Initialize Sample Data",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/init-sample-data",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["init-sample-data"]
