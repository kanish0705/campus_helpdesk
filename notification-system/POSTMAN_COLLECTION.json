        {
          "name": "Get Attendance Report - By Date",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/attendance/report?date=2024-04-21",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["attendance", "report"],
              "query": [
                {
                  "key": "date",
                  "value": "2024-04-21"
                }
              ]
            }
          },
          "description": "Get attendance records for specific date"
