        {
          "name": "Mark Attendance - Custom Date",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": \"S003\",\n  \"status\": \"absent\",\n  \"date\": \"2024-04-20\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/attendance/mark",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["attendance", "mark"]
            }
          },
          "description": "Mark attendance for a specific date"
        },
        {
          "name": "Get Attendance Report - All",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/attendance/report",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["attendance", "report"]
