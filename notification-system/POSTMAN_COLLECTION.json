              "raw": "http://localhost:5000/attendance/report?student_id=S001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["attendance", "report"],
              "query": [
                {
                  "key": "student_id",
                  "value": "S001"
